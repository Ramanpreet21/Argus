# Argus API Scanner Configuration

# Rate limiting and timeouts
ARGUS_MAX_CONCURRENT_REQUESTS=10
ARGUS_REQUEST_TIMEOUT_SECONDS=10
ARGUS_RATE_LIMIT_BACKOFF_SECONDS=30

# Logging
ARGUS_LOG_LEVEL=INFO

# Optional: Global headers for all requests (e.g. for authorized testing)
# ARGUS_AUTH_HEADER="Authorization: Bearer YOUR_TOKEN_HERE"
